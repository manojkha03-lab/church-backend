PORT=5000
MONGO_URI=your_mongodb_uri
JWT_SECRET=your_secret_key_at_least_32_characters_long
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudinary (required for profile image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL for CORS (set to your custom domain or Vercel URL)
# For local dev: FRONTEND_URL=http://localhost:5173
# Example: FRONTEND_URL=https://mydomain.com
FRONTEND_URL=http://localhost:5173
# Comma-separated additional origins (e.g. www subdomain)
# Example: FRONTEND_URLS=https://www.mydomain.com
FRONTEND_URLS=

# Firebase Admin (for verifying Google/Phone login tokens)
# Option A: Full service account JSON (recommended for production)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
# Option B: Just project ID (limited — only works with Google public keys)
FIREBASE_PROJECT_ID=your-firebase-project-id